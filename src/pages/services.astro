---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import EstimateModal from '../components/EstimateModal.astro';

const title = 'Stump Grinding Jacksonville FL | Professional Stump Removal Services | Stump Masters Jax';
const description = 'Professional stump grinding services in Jacksonville, FL. Expert stump removal for residential and commercial properties. Veteran-owned, licensed & insured. Same-day service. Call 904-408-2450';
---

<BaseLayout title={title} description={description}>
  <Header />
  <Breadcrumbs items={[
    { label: 'Home', url: '/' },
    { label: 'Services' }
  ]} />
  
  <main>
    <!-- Services Overview -->
    <section class="section bg-gray-700">
      <div class="container-standard">
        <h1 class="text-4xl md:text-5xl font-bold text-brand-yellow text-center mb-8">
          Professional Stump Grinding Services
        </h1>
        <div class="section-divider"></div>
        <p class="section-intro text-center">
          Expert stump grinding and removal services for residential and commercial properties throughout Northeast Florida
        </p>
        
        <!-- Service Cards -->
        <div class="max-w-4xl mx-auto text-center mb-12">
          <!-- Stump Grinding -->
          <div class="service-card block hover:bg-gray-800 transition-all duration-200 group cursor-pointer max-w-2xl mx-auto">
            <h3 class="text-2xl font-bold text-brand-yellow mb-4 group-hover:text-yellow-400 transition-colors">Stump Grinding & Removal</h3>
            <p class="text-body mb-4">
              Professional stump grinding services that remove tree stumps below ground level. State-of-the-art equipment handles stumps of any size with minimal yard disruption.
            </p>
            <ul class="space-y-1 mb-4">
              <li class="flex items-start gap-2">
                <span class="text-brand-yellow text-lg mt-0.5">✓</span>
                <span class="text-gray-300 text-sm">Below-ground grinding (6-12 inches)</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-brand-yellow text-lg mt-0.5">✓</span>
                <span class="text-gray-300 text-sm">Stumps of all sizes</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-brand-yellow text-lg mt-0.5">✓</span>
                <span class="text-gray-300 text-sm">Same-day service available</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-brand-yellow text-lg mt-0.5">✓</span>
                <span class="text-gray-300 text-sm">Clean finish guaranteed</span>
              </li>
            </ul>
            <div class="text-center mt-auto pt-6">
              <a href="/services/stump-grinding" class="inline-flex items-center justify-center px-6 py-3 bg-brand-yellow text-black font-bold rounded-md hover:bg-yellow-400 transition-all duration-200 shadow-md hover:shadow-lg transform hover:-translate-y-0.5 group">
                <span class="text-sm">Learn More</span>
                <svg class="w-4 h-4 ml-2 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
  <EstimateModal />
</BaseLayout>
